{
  "name": "@swift-newt/server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "migrate": "bun run src/db/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@mozilla/readability": "^0.5.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "jsdom": "^25.0.0",
    "node-cron": "^3.0.3",
    "p-queue": "^8.0.1",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsdom": "^21.1.7",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.0"
  }
}
