# Generate with: openssl rand -base64 32
MASTER_KEY=

# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Set after running first-run setup in the PWA.
# The setup endpoint prints the line to add here.
USER_PASSWORD_HASH=

# Public origin used for CORS + cookie Secure flag.
# Use your tunneled HTTPS URL on iPhone Safari to install as PWA.
PUBLIC_ORIGIN=http://localhost:8787

PORT=8787
DB_PATH=/data/swift-newt.sqlite
